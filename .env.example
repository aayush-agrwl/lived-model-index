# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Neon pooled Postgres connection string
DATABASE_URL=postgresql://neondb_owner:XXXX@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# LLM provider API keys (all free tier)
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...

# Random 64-char hex strings — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace-with-random-hex
ADMIN_PASSWORD=replace-with-random-hex
